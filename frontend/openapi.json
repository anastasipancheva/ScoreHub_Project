{
  "openapi": "3.0.1",
  "info": {
    "title": "ScoreHub API",
    "description": "API для автоматизации МКН2: курсы, занятия, команды, КТ, уведомления, JWT.\r\n\r\n**OpenAPI (Swagger) JSON:** после запуска приложения скачайте спецификацию по адресу `/swagger/v1/swagger.json` (относительно базового URL сервера).\r\n\r\n**Авторизация:** нажмите «Authorize» и вставьте JWT (с префиксом `Bearer ` или без — зависит от клиента).",
    "version": "v1"
  },
  "paths": {
    "/api/admin/users/{userId}/roles": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Назначить пользователю роль (Student, Assistant, Teacher, Admin).",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "description": "Идентификатор пользователя.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "description": "Имя роли в поле roleName.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetRoleDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SetRoleDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SetRoleDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/activities/{activityId}/help-requests": {
      "get": {
        "tags": [
          "AssistantSession"
